{
  "manifest_version": 3,
  "name": "TeamTweaker",
  "version": "1.0.7",
  "description": "Modify and improve the appearance of Microsoft Teams in your browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "teamtweaker@neijix",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting", "sidePanel"],
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles/base.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
